rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function role(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function isPrivilegedUser(uid) {
      return signedIn() &&
        (role(uid) == 'admin' || role(uid) == 'owner' || role(uid) == 'manager');
    }

    // ✅ allow serverTimestamp() by NOT validating uploadedAt on create
    function isValidProjectFileCreate() {
      return request.resource.data.uploaderId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.url is string
        && request.resource.data.fullPath is string
        && request.resource.data.size is number
        && request.resource.data.type is string;
    }

    // ---- USERS ----
    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;

      allow read: if signedIn() &&
        (request.auth.uid == userId || isPrivilegedUser(request.auth.uid));

      allow update: if signedIn() &&
        (request.auth.uid == userId || isPrivilegedUser(request.auth.uid));

      allow delete: if role(request.auth.uid) == 'owner';

      allow list: if isPrivilegedUser(request.auth.uid);

      match /pushSubscriptions/{docId} {
        allow read, write, delete: if signedIn() && request.auth.uid == userId;
      }
    }

    // ---- SHIFTS ----
    match /shifts/{shiftId} {
      allow read: if signedIn();
      allow create, delete: if isPrivilegedUser(request.auth.uid);

      allow update: if signedIn() &&
        (
          (resource.data.userId == request.auth.uid &&
           request.resource.data.userId == request.auth.uid)
          || isPrivilegedUser(request.auth.uid)
        );
    }

    // ---- PROJECTS ----
    match /projects/{projectId} {
      allow read: if signedIn();
      allow create, update: if isPrivilegedUser(request.auth.uid);

      match /files/{fileId} {
        allow read: if signedIn();

        // ✅ uploader can create their own file record
        allow create: if signedIn() && isValidProjectFileCreate();

        // ✅ only uploader OR privileged can delete
        allow delete: if signedIn() &&
          (isPrivilegedUser(request.auth.uid) || resource.data.uploaderId == request.auth.uid);

        // ✅ block edits
        allow update: if false;
      }
    }

    // ---- ANNOUNCEMENTS ----
    match /announcements/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isPrivilegedUser(request.auth.uid);
    }

    // ---- ANNOUNCEMENT ACKNOWLEDGEMENTS ----
    match /announcementAcknowledgements/{docId} {
      allow read: if signedIn();

      allow create, update, delete: if signedIn()
        && request.resource.data.userId == request.auth.uid;
    }

    // ---- SETTINGS ----
    match /settings/{id} {
      allow read, write: if role(request.auth.uid) == 'owner';
    }

    // ---- TRADE TASKS ----
    match /trade_tasks/{id} {
      allow read: if signedIn();
      allow write: if isPrivilegedUser(request.auth.uid);
    }

    // ---- UNAVAILABILITY ----
    match /unavailability/{id} {
      allow read: if signedIn();
      allow write: if isPrivilegedUser(request.auth.uid);
    }

    // ---- HEALTH & SAFETY FILES ----
    match /health_and_safety_files/{id} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.uploaderId == request.auth.uid;

      allow delete: if role(request.auth.uid) == 'owner'
        || resource.data.uploaderId == request.auth.uid;

      allow update: if false;
    }
  }
}
